import subprocess

def run_command(cmd):
    """Esegue un comando e ritorna l'output decodificato."""
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout

def main():
    print("=== Lista profili WiFi salvati ===\n")

    # 1. Mostra i profili WiFi
    profiles_output = run_command("netsh wlan show profiles")
    print(profiles_output)

    # 2. Estrae i nomi dei profili
    profiles = []
    for line in profiles_output.splitlines():
        if "Tutti i profili utente" in line or "All User Profile" in line:
            name = line.split(":")[1].strip()
            profiles.append(name)

    if not profiles:
        print("Nessun profilo WiFi trovato.")
        return

    # 3. Mostra elenco numerato
    print("\n=== Seleziona una rete WiFi ===")
    for i, p in enumerate(profiles, start=1):
        print(f"{i}. {p}")

    # 4. Input utente
    choice = input("\nInserisci il numero della rete: ")

    try:
        choice = int(choice)
        wifi_name = profiles[choice - 1]
    except:
        print("Scelta non valida.")
        return

    print(f"\n=== Dettagli rete: {wifi_name} ===\n")

    # 5. Mostra dettagli con password
    details_output = run_command(f'netsh wlan show profile name="{wifi_name}" key=clear')
    print(details_output)

    # 6. Salva in file TXT
    filename = f"{wifi_name}.txt"
    with open(filename, "w", encoding="utf-8") as f:
        f.write(details_output)

    print(f"\nOutput salvato nel file: {filename}")

if __name__ == "__main__":
    main()
